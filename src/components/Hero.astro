---
import { siteConfig } from "../config";

const { lang } = Astro.props;
---

<section
  id="hero"
  class="flex min-h-screen items-center bg-white px-8 sm:px-12 md:px-16 lg:px-24"
>
  <div>
    {
      lang.hero.hello && (
        <p class="mb-4 text-lg text-gray-500">
          {lang.hero.hello}
        </p>
      )
    }

    {
      lang.hero.im && (
        <p class="mb-2 text-2xl sm:text-3xl font-medium text-gray-500">
          {lang.hero.im}
        </p>
      )
    }

    <h1 class="text-5xl sm:text-6xl md:text-7xl xl:text-8xl font-bold text-gray-900">
      {siteConfig.name}
    </h1>

    <div
      class="w-[75px] h-[5px] mt-3 rounded-full"
      style={`background-color: ${siteConfig.accentColor}`}
    />

    {
      lang.hero.title && (
        <p class="mt-6 max-w-xl text-lg text-gray-600 leading-relaxed">
          {lang.hero.title}
        </p>
      )
    }

    <a
      href="#projects"
      class="inline-block mt-10 rounded-xl bg-gray-900 px-6 py-3 text-white font-medium transition-all duration-300 hover:bg-gray-800 hover:-translate-y-1"
    >
      {lang.projects.title}
    </a>
  </div>
</section>