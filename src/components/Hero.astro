---
import { siteConfig } from "../config";

const { lang } = Astro.props;
---

<section
  id="hero"
  class="relative flex min-h-screen items-center justify-center overflow-hidden bg-white"
  style={`--accent:${siteConfig.accentColor}`}
>
  <!-- Background -->
  <div
    class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,var(--accent),transparent_45%)] opacity-20"
  />

  <div class="mx-auto max-w-4xl px-6 text-center">

    <p class="mb-4 text-lg text-gray-500">
      {lang.hero.hello}
    </p>

    <h1 class="text-5xl font-black tracking-tight leading-tight sm:text-7xl">
      {lang.hero.im}
      <span
        class="block bg-gradient-to-r from-[var(--accent)] to-sky-500 bg-clip-text text-transparent"
      >
        {siteConfig.name}
      </span>
    </h1>

    <p class="mx-auto mt-8 max-w-2xl text-lg leading-8 text-gray-600">
      {lang.hero.title}
    </p>

    <div class="mt-12 flex justify-center gap-4">

      <a
        href="#projects"
        class="rounded-xl bg-[var(--accent)] px-6 py-3 font-semibold text-white transition hover:scale-105"
      >
        {lang.projects.title}
      </a>

    </div>    

  </div>
</section>